{
  "name": "@pathrix/social-dispatch",
  "version": "0.1.0",
  "description": "Publishing arm for Pathrix. Schedules and dispatches content to Instagram, Threads, Facebook Page, Reddit, YouTube, and X via their native APIs. Exposes everything as MCP tools.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./auth/meta": {
      "types": "./src/auth/meta.ts",
      "import": "./src/auth/meta.ts",
      "default": "./src/auth/meta.ts"
    },
    "./auth/youtube": {
      "types": "./src/auth/youtube.ts",
      "import": "./src/auth/youtube.ts",
      "default": "./src/auth/youtube.ts"
    },
    "./auth/x": {
      "types": "./src/auth/x.ts",
      "import": "./src/auth/x.ts",
      "default": "./src/auth/x.ts"
    },
    "./auth/gmail": {
      "types": "./src/auth/gmail.ts",
      "import": "./src/auth/gmail.ts",
      "default": "./src/auth/gmail.ts"
    },
    "./owned-profile/service": {
      "types": "./src/owned-profile/service.ts",
      "import": "./src/owned-profile/service.ts",
      "default": "./src/owned-profile/service.ts"
    },
    "./token-refresher": {
      "types": "./src/token-refresher.ts",
      "import": "./src/token-refresher.ts",
      "default": "./src/token-refresher.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": ">=3.0.0 <5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": ["mcp", "claude", "social-media", "instagram", "reddit", "youtube", "x", "threads", "dispatch"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gauravsaxena1997/pathrix-social-dispatch-mcp"
  }
}
